---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'> & { active?: boolean };

const { href, class: className, active: activeOverride, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const isActive =
	activeOverride ??
	(href === pathname || href === '/' + (subpath?.[0] || ''));
const resolvedHref = href?.startsWith('/') ? import.meta.env.BASE_URL.replace(/\/$/, '') + href : href;
---

<a href={resolvedHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
