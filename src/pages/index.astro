---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { readingTime, stripHtml } from '../scripts/reading-time';

const posts = (await getCollection('blog', ({ data }) => !data.isDraft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))].sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 3rem;
				align-items: center;
			}
			.filter-label {
				font-size: 0.8em;
				color: rgba(229, 233, 240, 0.5);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-right: 0.25rem;
			}
			.tag-btn {
				padding: 0.3em 0.85em;
				border-radius: 999px;
				border: 1px solid rgba(229, 233, 240, 0.15);
				background: transparent;
				color: rgba(229, 233, 240, 0.65);
				font-size: 0.8em;
				font-family: inherit;
				cursor: pointer;
				transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
			}
			.tag-btn:hover {
				background: rgba(229, 233, 240, 0.08);
				color: rgb(229, 233, 240);
				border-color: rgba(229, 233, 240, 0.3);
			}
			.tag-btn.active {
				background: rgba(46, 148, 21, 0.15);
				color: var(--accent);
				border-color: var(--accent);
			}

			/* Timeline */
			.timeline {
				list-style: none;
				margin: 0;
				padding: 0;
				position: relative;
			}
			.timeline::before {
				content: '';
				position: absolute;
				left: 9rem;
				top: 0;
				bottom: 0;
				width: 1px;
				background: rgba(229, 233, 240, 0.1);
			}
			.timeline li {
				display: grid;
				grid-template-columns: 9rem 1fr;
				gap: 0 2rem;
				padding: 1.5rem 0;
				border-bottom: 1px solid rgba(229, 233, 240, 0.06);
				position: relative;
			}
			.timeline li:last-child {
				border-bottom: none;
			}
			.timeline li::before {
				content: '';
				position: absolute;
				left: calc(9rem - 3px);
				top: 2rem;
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: rgba(229, 233, 240, 0.2);
				border: 1px solid rgba(229, 233, 240, 0.4);
				transition: background 0.15s ease, border-color 0.15s ease;
			}
			.timeline li:hover::before {
				background: var(--accent);
				border-color: var(--accent);
			}
			.post-date {
				font-size: 0.8em;
				color: rgba(229, 233, 240, 0.4);
				padding-top: 0.2rem;
				padding-right: 1rem;
				text-align: right;
				font-variant-numeric: tabular-nums;
				line-height: 1.6;
			}
			.post-body {
				display: flex;
				flex-direction: column;
				gap: 0.3rem;
			}
			.post-body a {
				text-decoration: none;
				color: inherit;
			}
			.post-title {
				margin: 0;
				font-size: 1.1rem;
				font-weight: 600;
				color: rgb(var(--gray-light));
				line-height: 1.3;
				transition: color 0.15s ease;
			}
			.post-body a:hover .post-title {
				color: var(--accent);
			}
			.post-description {
				margin: 0;
				font-size: 0.88em;
				color: rgba(229, 233, 240, 0.5);
				line-height: 1.55;
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3rem;
				margin-top: 0.2rem;
			}
			.post-tag {
				font-size: 0.7em;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				background: rgba(46, 148, 21, 0.12);
				color: var(--accent);
				border: 1px solid rgba(46, 148, 21, 0.3);
			}
			.no-results {
				display: none;
				color: rgba(229, 233, 240, 0.45);
				font-size: 0.95em;
				padding: 2rem 0;
			}
			.no-results.visible {
				display: block;
			}
			.pagination {
				display: none;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				margin-top: 2.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(229, 233, 240, 0.06);
			}
			.pagination.visible {
				display: flex;
			}
			.page-btn {
				padding: 0.35em 0.9em;
				border-radius: 999px;
				border: 1px solid rgba(229, 233, 240, 0.15);
				background: transparent;
				color: rgba(229, 233, 240, 0.65);
				font-size: 0.85em;
				font-family: inherit;
				cursor: pointer;
				transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
			}
			.page-btn:hover:not(:disabled) {
				background: rgba(229, 233, 240, 0.08);
				color: rgb(229, 233, 240);
				border-color: rgba(229, 233, 240, 0.3);
			}
			.page-btn:disabled {
				opacity: 0.25;
				cursor: default;
			}
			.page-info {
				font-size: 0.8em;
				color: rgba(229, 233, 240, 0.4);
				padding: 0 0.5rem;
			}
			@media (max-width: 720px) {
				.timeline::before {
					display: none;
				}
				.timeline li {
					grid-template-columns: 1fr;
					gap: 0.25rem;
					padding: 1.25rem 0;
				}
				.timeline li::before {
					display: none;
				}
				.post-date {
					text-align: left;
					font-size: 0.75em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="filter-bar">
					<span class="filter-label">Filter</span>
					<button class="tag-btn active" data-tag="all">All</button>
					{allTags.map((tag) => (
						<button class="tag-btn" data-tag={tag}>{tag}</button>
					))}
				</div>
				<ul class="timeline" id="post-list">
					{
						posts.map((post) => (
							<li data-tags={(post.data.tags ?? []).join(',')}>
								<div class="post-date">
									<FormattedDate date={post.data.pubDate} />
									{post.body && <div>{readingTime(post.body)} min read</div>}
								</div>
								<div class="post-body">
									<a href={`${import.meta.env.BASE_URL}/${post.id}/`}>
										<h4 class="post-title">{stripHtml(post.data.title)}</h4>
									</a>
									{post.data.description && (
										<p class="post-description">{post.data.description}</p>
									)}
									{post.data.tags && post.data.tags.length > 0 && (
										<div class="post-tags">
											{post.data.tags.map((tag) => (
												<span class="post-tag">{tag}</span>
											))}
										</div>
									)}
								</div>
							</li>
						))
					}
				</ul>
				<p class="no-results" id="no-results">No posts found for this tag.</p>
				<div class="pagination" id="pagination">
					<button class="page-btn" id="prev">← Prev</button>
					<span class="page-info" id="page-info"></span>
					<button class="page-btn" id="next">Next →</button>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			const PAGE_SIZE = 25;

			const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
			const items = Array.from(document.querySelectorAll<HTMLLIElement>('#post-list li'));
			const noResults = document.getElementById('no-results')!;
			const pagination = document.getElementById('pagination')!;
			const prevBtn = document.getElementById('prev') as HTMLButtonElement;
			const nextBtn = document.getElementById('next') as HTMLButtonElement;
			const pageInfo = document.getElementById('page-info')!;

			let currentTag = 'all';
			let currentPage = 1;

			function getFiltered(): HTMLLIElement[] {
				return items.filter((li) => {
					const tags = (li.dataset.tags ?? '').split(',').filter(Boolean);
					return currentTag === 'all' || tags.includes(currentTag);
				});
			}

			function render() {
				const filtered = getFiltered();
				const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
				currentPage = Math.min(currentPage, totalPages);

				const start = (currentPage - 1) * PAGE_SIZE;
				const end = start + PAGE_SIZE;

				items.forEach((li) => (li.style.display = 'none'));
				filtered.forEach((li, i) => {
					li.style.display = i >= start && i < end ? '' : 'none';
				});

				noResults.classList.toggle('visible', filtered.length === 0);

				const showPagination = filtered.length > PAGE_SIZE;
				pagination.classList.toggle('visible', showPagination);
				if (showPagination) {
					pageInfo.textContent = `${currentPage} / ${totalPages}`;
					prevBtn.disabled = currentPage === 1;
					nextBtn.disabled = currentPage === totalPages;
				}
			}

			buttons.forEach((btn) => {
				btn.addEventListener('click', () => {
					currentTag = btn.dataset.tag ?? 'all';
					currentPage = 1;
					buttons.forEach((b) => b.classList.toggle('active', b === btn));
					render();
				});
			});

			prevBtn.addEventListener('click', () => { currentPage--; render(); });
			nextBtn.addEventListener('click', () => { currentPage++; render(); });

			render();
		</script>
	</body>
</html>
