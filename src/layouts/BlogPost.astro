---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { readingTime } from "../scripts/reading-time";

type BlogData = CollectionEntry<"blog">["data"];
interface Props extends BlogData {
	body?: string;
	prevPost?: CollectionEntry<"blog"> | null;
	nextPost?: CollectionEntry<"blog"> | null;
}

const { title, description, pubDate, updatedDate, heroImage, tags, body, prevPost, nextPost } = Astro.props;
const readTime = body ? readingTime(body) : null;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} type="article" pubDate={pubDate} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.layout {
				max-width: 720px;
				margin: 0 auto;
				padding: 3em 1em;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: 100%;
				margin: auto;
				padding: 1em;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.reading-time {
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.image-wrapper {
				margin-bottom: 2.5em;
			}
			.post-tags {
				display: inline-flex;
				flex-wrap: wrap;
				gap: 0.35rem;
				vertical-align: middle;
				margin-left: 0.4rem;
			}
			.post-tag {
				font-size: 0.7em;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				background: rgba(46, 148, 21, 0.12);
				color: var(--accent);
				border: 1px solid rgba(46, 148, 21, 0.3);
				vertical-align: middle;
			}
			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(229, 233, 240, 0.08);
			}
			.post-nav-item {
				display: flex;
				flex-direction: column;
			}
			.post-nav-item.next {
				align-items: flex-end;
				text-align: right;
			}
			.post-nav-item a {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
				text-decoration: none;
				color: inherit;
			}
			.nav-label {
				font-size: 0.75em;
				color: rgba(229, 233, 240, 0.4);
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}
			.nav-title {
				font-size: 0.9em;
				color: rgba(229, 233, 240, 0.7);
				transition: color 0.15s;
				line-height: 1.4;
			}
			.post-nav-item a:hover .nav-title {
				color: var(--accent);
			}
			@media (max-width: 480px) {
				.post-nav {
					grid-template-columns: 1fr;
				}
				.post-nav-item.next {
					align-items: flex-start;
					text-align: left;
				}
			}

			/* TOC — fixed strip spanning the free space right of the prose,
			   nav card centered inside it */
			:global(.toc-sidebar) {
				display: none;
			}
			@media (min-width: 1280px) {
				:global(.toc-sidebar) {
					display: flex;
					justify-content: center;
					align-items: flex-start;
					position: fixed;
					top: 5rem;
					/* start right at the prose right edge */
					left: calc(50vw + 360px);
					right: 0;
					pointer-events: none;
					padding: 0 1.5rem;
				}
				:global(.toc-sidebar > nav) {
					pointer-events: auto;
					width: 230px;
					max-height: calc(100vh - 6rem);
					overflow-y: auto;
					padding: 1rem 1.1rem;
					background: rgba(96, 165, 250, 0.07);
					border: 1px solid rgba(96, 165, 250, 0.25);
					border-radius: 10px;
					box-shadow: 0 2px 20px rgba(96, 165, 250, 0.1);
				}
			}
			:global(#toc-heading) {
				font-size: 0.72rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgba(147, 197, 253, 0.7);
				margin: 0 0 0.85rem 0;
			}
			:global(#toc-list) {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			:global(#toc-list li) {
				margin: 0.15rem 0;
				display: flex;
				align-items: baseline;
				gap: 0.4rem;
			}
			:global(#toc-list li::before) {
				content: "•";
				font-size: 0.6rem;
				color: rgba(96, 165, 250, 0.4);
				flex-shrink: 0;
				margin-top: 0.1rem;
			}
			:global(#toc-list li.h2) {
				padding-left: 0.8rem;
			}
			:global(#toc-list li.h2::before) {
				content: "–";
				font-size: 0.65rem;
				color: rgba(96, 165, 250, 0.3);
			}
			:global(#toc-list li.h3) {
				padding-left: 1.6rem;
			}
			:global(#toc-list li.h3::before) {
				content: "·";
				font-size: 0.65rem;
				color: rgba(96, 165, 250, 0.2);
			}
			:global(#toc-list a) {
				font-size: 0.82rem;
				line-height: 1.5;
				color: rgba(147, 197, 253, 0.5) !important;
				text-decoration: none !important;
				display: block;
				padding: 0.15rem 0;
				border-radius: 5px;
				transition: color 0.15s;
				flex: 1;
			}
			:global(#toc-list a:hover) {
				color: rgba(147, 197, 253, 0.9) !important;
			}
			:global(#toc-list a.active) {
				color: #93c5fd !important;
				font-weight: 600;
			}
			:global(#toc-list li:has(a.active)::before) {
				color: #93c5fd;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="layout">
				<article>
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{readTime && <span class="reading-time"> · {readTime} min read</span>}
								{tags && tags.length > 0 && (
									<span class="post-tags">
										{tags.map(tag => <span class="post-tag">{tag}</span>)}
									</span>
								)}
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on{" "}
											<FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<div class="image-wrapper">
							{
								heroImage && (
									<div class="hero-image">
										<Image
											width={1020}
											height={510}
											src={heroImage}
											alt=""
										/>
									</div>
								)
							}
						</div>
						<slot />
						{(prevPost || nextPost) && (
							<nav class="post-nav">
								<div class="post-nav-item prev">
									{prevPost && (
										<a href={`${import.meta.env.BASE_URL}/${prevPost.id}/`}>
											<span class="nav-label">← Older</span>
											<span class="nav-title">{prevPost.data.title}</span>
										</a>
									)}
								</div>
								<div class="post-nav-item next">
									{nextPost && (
										<a href={`${import.meta.env.BASE_URL}/${nextPost.id}/`}>
											<span class="nav-label">Newer →</span>
											<span class="nav-title">{nextPost.data.title}</span>
										</a>
									)}
								</div>
							</nav>
						)}
					</div>
				</article>
			</div>
		</main>
		<aside class="toc-sidebar">
			<nav aria-label="Table of contents">
				<h2 id="toc-heading">Table of contents</h2>
				<ul id="toc-list"></ul>
			</nav>
		</aside>
		<Footer />

		<script>
			// exclude the post title h1 which lives inside .title
			const headings = Array.from(
				document.querySelectorAll("article h1, article h2, article h3")
			).filter((h) => !h.closest(".title"));
			const tocList = document.getElementById("toc-list");

			if (tocList && headings.length > 0) {
				headings.forEach((heading, index) => {
					if (!heading.id) heading.id = `heading-${index}`;

					const li = document.createElement("li");
					if (heading.tagName === "H2") li.classList.add("h2");
					if (heading.tagName === "H3") li.classList.add("h3");

					const a = document.createElement("a");
					a.href = `#${heading.id}`;
					a.textContent = heading.textContent ?? "";

					li.appendChild(a);
					tocList.appendChild(li);
				});

				const HEADER_HEIGHT = 84; // 5rem in px

				function updateActive() {
					let current: Element | null = null;
					for (const h of headings) {
						if (h.getBoundingClientRect().top <= HEADER_HEIGHT + 8) {
							current = h;
						}
					}
					tocList.querySelectorAll("a").forEach((a) => a.classList.remove("active"));
					if (current) {
						tocList
							.querySelector(`a[href="#${current.id}"]`)
							?.classList.add("active");
					}
				}

				window.addEventListener("scroll", updateActive, { passive: true });
				updateActive();
			}
		</script>
	</body>
</html>
